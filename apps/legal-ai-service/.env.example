# legal-ai-service - copia a .env y rellena valores
PORT=8081

# AI Router - al menos una clave según taskType
# CLASSIFY → OpenAI (gpt-4o-mini)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# DEEP_ANALYSIS → Anthropic (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=
# LEGAL_AI_MODEL=claude-sonnet-4-20250514

# MASSIVE_SUMMARY → Google Gemini (expedientes 50+ páginas)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-pro

# S3 - mismas credenciales que la API principal
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Seguridad: token para validar llamadas entre servicios
# Header: x-internal-token: <INTERNAL_API_KEY>
INTERNAL_API_KEY=

# Callback automático a la API (permite usar solo 1 túnel ngrok)
# Si LEX_API_BASE_URL y LEX_API_INTERNAL_TOKEN están configurados, tras analizar
# se hace PATCH a la API. El token debe coincidir con INTERNAL_WEBHOOK_TOKEN o INTERNAL_API_KEY.
# En local: LEX_API_BASE_URL=http://localhost:3001
LEX_API_BASE_URL=
LEX_API_INTERNAL_TOKEN=
