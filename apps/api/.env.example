# API - copia a .env y rellena valores
PORT=3001
DATABASE_URL="postgresql://user:password@localhost:5432/lex_cloud"
# Misma Secret Key que en apps/web/.env.local (Clerk Dashboard → API Keys → Secret key)
CLERK_SECRET_KEY=
# Opcional. Si obtienes 403 al cargar el resumen, deja vacío o bórralo: la API usará JWKS por red.
CLERK_JWT_KEY=
# Origen del frontend (para validar claim azp del JWT). Por defecto http://localhost:3000.
# Si tu web corre en otro puerto, ej: FRONTEND_URL=http://localhost:3002
# FRONTEND_URL=http://localhost:3000
CLERK_WEBHOOK_SIGNING_SECRET=
ANTHROPIC_API_KEY=
# OPENAI_API_KEY: fallback cuando Anthropic no tiene créditos (usa gpt-4o-mini)
OPENAI_API_KEY=
# GEMINI_API_KEY: segundo fallback (usa gemini-1.5-flash)
GEMINI_API_KEY=
AWS_S3_BUCKET=
AWS_REGION=eu-west-1

# Bus de eventos
EVENT_BUS_MODE=webhook
EVENT_BUS_DOCUMENT_UPLOADED_URL=http://localhost:5678/webhook/document-uploaded
EVENT_BUS_INTERNAL_TOKEN=
EVENT_BUS_HMAC_SECRET=
AWS_SNS_TOPIC_DOCUMENT_UPLOADED_ARN=
AWS_SQS_DLQ_URL=
AWS_ENDPOINT_URL_SNS=http://localhost:4566
AWS_ENDPOINT_URL_SQS=http://localhost:4566

# Seguridad callback interno
INTERNAL_WEBHOOK_TOKEN=
INTERNAL_WEBHOOK_HMAC_SECRET=

# Alertas
WORKFLOW_FAILURE_ALERT_THRESHOLD=3
SLACK_WEBHOOK_URL=

# Cifrado por tenant
DEFAULT_TENANT_KMS_KEY_ID=

# BullMQ (jobs pesados)
BULLMQ_ENABLED=false
BULLMQ_REDIS_URL=redis://localhost:6379
BULLMQ_HEAVY_QUEUE_NAME=lex:heavy-jobs

# legal-ai-service
LEGAL_AI_SERVICE_URL=http://localhost:8081
# LEGAL_AI_MOCK=true → análisis simulado (sin API), no aplica límite de uso

# USE_LOCAL_AI_ONLY=true → desactiva n8n y event bus, usa solo LegalAIService (Anthropic/OpenAI/Gemini)
USE_LOCAL_AI_ONLY=

# n8n - orquestador de workflows (omitir si USE_LOCAL_AI_ONLY=true)
# N8N_WEBHOOK_URL: webhook para disparar flujos al subir/reanalizar
# Header Auth (si el webhook de n8n lo requiere):
#   N8N_WEBHOOK_AUTH_HEADER = nombre del header (ej: x-n8n-auth)
#   N8N_WEBHOOK_AUTH_VALUE = valor secreto (el mismo que en n8n)
N8N_WEBHOOK_URL=
N8N_WEBHOOK_AUTH_HEADER=
N8N_WEBHOOK_AUTH_VALUE=

# Enlaces compartidos públicos de documentos
PUBLIC_WEB_BASE_URL=http://localhost:3000