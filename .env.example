# =============================================================================
# LEX-CLOUD — Variables de entorno de ejemplo
# =============================================================================
# Copia este archivo a .env en la raíz o en apps/api y apps/web según corresponda.
# Nunca subas archivos .env al repositorio.

# -----------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# -----------------------------------------------------------------------------
# Usado por: API (Prisma)
# Dónde obtenerlo: Crea una base PostgreSQL local, en Docker, o en un proveedor
# (Supabase, Neon, Railway, AWS RDS, etc.). La URL incluye usuario, contraseña,
# host, puerto y nombre de la base.
# Ejemplo local: postgresql://usuario:password@localhost:5432/lex_cloud
# Ejemplo con SSL: postgresql://user:pass@host:5432/db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"

# -----------------------------------------------------------------------------
# CLERK (Autenticación y organizaciones)
# -----------------------------------------------------------------------------
# Usado por: API (verificación JWT, webhooks, sync) y Web (auth en el navegador)

# Publishable Key — Público, se usa en el frontend (Next.js).
# Dónde: Clerk Dashboard → API Keys → Publishable key
# En desarrollo con Keyless, Clerk puede generarla automáticamente.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Secret Key — Privado, solo en el backend (API).
# Dónde: Clerk Dashboard → API Keys → Secret key
# Necesaria para verifyToken(), webhooks y obtener datos de usuario/org.
CLERK_SECRET_KEY="sk_test_..."

# (Opcional) JWT public key en formato PEM — Verificación de tokens sin red.
# Dónde: Clerk Dashboard → API Keys → JWT public key (PEM)
# Si se define, el backend puede verificar JWTs sin llamar a Clerk.
# CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Webhook Signing Secret — Para validar que los webhooks son de Clerk.
# Dónde: Clerk Dashboard → Webhooks → [Tu endpoint] → Signing secret (whsec_...)
# Necesario en la API para el endpoint POST que recibe user.created / organization.created.
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# AWS S3 (Almacenamiento de documentos)
# -----------------------------------------------------------------------------
# Usado por: API (subida/descarga de documentos de expedientes)
# Dónde obtenerlo: AWS Console → IAM → Usuarios → Claves de acceso;
# o crear un bucket en S3 y un usuario IAM con política s3:PutObject, GetObject, DeleteObject.

# Nombre del bucket donde se guardan los archivos.
AWS_S3_BUCKET="lex-cloud-documents"

# Región del bucket (ej. eu-west-1, us-east-1).
AWS_REGION="eu-west-1"

# Access Key ID del usuario IAM con permisos sobre el bucket.
AWS_ACCESS_KEY_ID="AKIA..."

# Secret Access Key (solo en backend, nunca en el frontend).
AWS_SECRET_ACCESS_KEY="..."

# (Opcional) Endpoint personalizado para S3-compatible (MinIO, DigitalOcean Spaces, etc.).
# AWS_S3_ENDPOINT="https://s3.eu-west-1.amazonaws.com"

# -----------------------------------------------------------------------------
# IA — Análisis legal (Claude / OpenAI)
# -----------------------------------------------------------------------------
# Usado por: API (módulo de análisis de documentos con LangChain + Claude)
# Dónde: Anthropic → API Keys para Claude; OpenAI → API Keys para OpenAI.

# Claude (Anthropic) — Recomendado para análisis legal.
# Dónde: https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY="sk-ant-..."

# -----------------------------------------------------------------------------
# EVENT BUS / WORKFLOWS (n8n / workers externos)
# -----------------------------------------------------------------------------
# URL interna donde la API publicará el evento DOCUMENT_UPLOADED.
# Puede apuntar a un webhook de n8n que luego envía el trabajo al worker de IA.
EVENT_BUS_DOCUMENT_UPLOADED_URL="https://n8n.example.com/webhook/document-uploaded"
# En local con docker-compose n8n suele ser:
# EVENT_BUS_DOCUMENT_UPLOADED_URL="http://localhost:5678/webhook/document-uploaded"

# Modo de transporte del bus:
# - webhook: API -> n8n webhook
# - sns: API -> AWS SNS (recomendado enterprise)
EVENT_BUS_MODE="webhook"
AWS_SNS_TOPIC_DOCUMENT_UPLOADED_ARN="arn:aws:sns:us-east-1:000000000000:lex-documents-uploaded"
AWS_SQS_DLQ_URL="http://localhost:4566/000000000000/lex-documents-dlq"

# Endpoints opcionales (localstack)
AWS_ENDPOINT_URL_SNS="http://localhost:4566"
AWS_ENDPOINT_URL_SQS="http://localhost:4566"

# Token opcional enviado por la API al webhook de orquestación.
EVENT_BUS_INTERNAL_TOKEN="internal-token-for-n8n"

# Secreto HMAC opcional para firmar el body enviado al webhook de orquestación.
EVENT_BUS_HMAC_SECRET="replace-with-strong-secret"

# Seguridad del endpoint interno que recibe resultados de workflows externos.
INTERNAL_WEBHOOK_TOKEN="replace-with-strong-internal-token"
INTERNAL_WEBHOOK_HMAC_SECRET="replace-with-strong-hmac-secret"

# Umbral de intentos fallidos para alertar en Slack (por defecto 3).
WORKFLOW_FAILURE_ALERT_THRESHOLD="3"

# Webhook de Slack para alertas de workflows fallidos.
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"

# KMS por tenant (fallback global si la org no define settings.kmsKeyId)
DEFAULT_TENANT_KMS_KEY_ID="arn:aws:kms:us-east-1:000000000000:key/replace-me"

# BullMQ para jobs pesados internos
BULLMQ_ENABLED="false"
BULLMQ_REDIS_URL="redis://localhost:6379"
BULLMQ_HEAVY_QUEUE_NAME="lex:heavy-jobs"

# -----------------------------------------------------------------------------
# n8n (opcional para docker-compose local)
# -----------------------------------------------------------------------------
N8N_BASIC_AUTH_USER="admin"
N8N_BASIC_AUTH_PASSWORD="admin123"

# legal-ai-service (microservicio separado)
LEGAL_AI_SERVICE_URL="http://localhost:8081"
LEGAL_AI_PROVIDER="mock"
LEGAL_AI_MODEL="mock-enterprise-v1"

# Alternativa: OpenAI (si usas modelos de OpenAI para el análisis).
# Dónde: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."

# -----------------------------------------------------------------------------
# API (NestJS) — Opcionales
# -----------------------------------------------------------------------------
# Puerto del servidor (por defecto 3000; en muchos setups la API usa 3001).
# PORT=3001

# -----------------------------------------------------------------------------
# WEB (Next.js) — Opcionales
# -----------------------------------------------------------------------------
# URL base del backend para las llamadas desde el frontend.
# En local: http://localhost:3001
# NEXT_PUBLIC_API_URL="http://localhost:3001"
